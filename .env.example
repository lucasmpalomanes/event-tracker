# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Auth0 — Applications → your app → Settings
# AUTH0_SECRET: generate with `openssl rand -hex 32`
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Resend (https://resend.com) — emails admins on join requests.
# Optional: leave RESEND_API_KEY empty to disable notifications.
# EMAIL_FROM must be a verified sender/domain in Resend; the
# onboarding@resend.dev default only delivers to your own account.
RESEND_API_KEY=
EMAIL_FROM=Event Tracker <onboarding@resend.dev>
