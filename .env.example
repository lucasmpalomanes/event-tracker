# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Auth0 — Applications → your app → Settings
# AUTH0_SECRET: generate with `openssl rand -hex 32`
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Mercado Pago (specs/pix-payments.md §5) — developers panel → your app.
# Test credentials locally, production credentials on Vercel.
# MP_WEBHOOK_SECRET: Webhooks → Configure notifications → secret key
# (test mode and production mode each have their own).
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=
